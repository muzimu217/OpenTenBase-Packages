#!/usr/bin/env bash
# =============================================================================
# opentenbase-ctl — OpenTenBase Cluster Management Script
# =============================================================================
# Manages an OpenTenBase cluster (GTM + Coordinator + Datanode) with
# versioned directory support.
#
# Usage:
#   opentenbase-ctl [OPTIONS] COMMAND
#
# Commands:
#   init      Initialize a new cluster (GTM + Coordinator + Datanode)
#   start     Start all cluster components
#   stop      Stop all cluster components
#   status    Show cluster status
#   restart   Stop then start the cluster
#   switch VERSION  Switch active version (updates /etc/opentenbase/current)
#
# Options:
#   -V, --version VERSION   Override active version (default: from /etc/opentenbase/current)
#   -h, --help              Show this help message
#   -q, --quiet             Suppress informational output
#
# Exit codes:
#   0 - Success
#   1 - Error
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
OT_BASE="/usr/lib/opentenbase"
OT_SYSCONF="/etc/opentenbase"
OT_DATA="/var/lib/opentenbase"
OT_LOG="/var/log/opentenbase"
CURRENT_LINK="${OT_SYSCONF}/current"

# Default ports
GTM_PORT=6666
COORD_PORT=5432
COORD_POOLER_PORT=6667
DN_PORT=15432
DN_POOLER_PORT=6668

STARTUP_TIMEOUT=60
QUIET=false

# ---------------------------------------------------------------------------
# Color output
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { [[ "$QUIET" == "true" ]] || echo -e "${CYAN}[INFO]${NC} $*"; }
log_ok()    { [[ "$QUIET" == "true" ]] || echo -e "${GREEN}[OK]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# ---------------------------------------------------------------------------
# Resolve active version
# ---------------------------------------------------------------------------
resolve_version() {
    if [[ -n "${OTB_VERSION_OVERRIDE:-}" ]]; then
        echo "$OTB_VERSION_OVERRIDE"
        return
    fi
    if [[ -L "$CURRENT_LINK" ]]; then
        local target
        target=$(readlink "$CURRENT_LINK")
        basename "$target"
    else
        # Fallback: find the first installed version
        local ver
        for ver in "${OT_BASE}"/*/; do
            local v
            v=$(basename "$ver")
            case "$v" in bin|lib|share|include) continue ;; esac
            echo "$v"
            return
        done
        echo "5.0"
    fi
}

# ---------------------------------------------------------------------------
# Resolve service user
# ---------------------------------------------------------------------------
resolve_service_user() {
    if id opentenbase >/dev/null 2>&1; then
        echo "opentenbase"
    elif id postgres >/dev/null 2>&1; then
        echo "postgres"
    else
        echo "$(whoami)"
    fi
}

# Run command as service user
as_svc() {
    local user="$1"
    shift
    if [[ "$user" == "$(whoami)" ]]; then
        "$@"
    else
        su -s /bin/bash -c "$*" "$user"
    fi
}

# ---------------------------------------------------------------------------
# Port check
# ---------------------------------------------------------------------------
check_port() {
    local port="$1"
    if command -v ss >/dev/null 2>&1; then
        ss -tlnp 2>/dev/null | grep -q ":${port} "
    elif command -v netstat >/dev/null 2>&1; then
        netstat -tlnp 2>/dev/null | grep -q ":${port} "
    else
        (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null
    fi
}

wait_for_port() {
    local port="$1"
    local timeout="$2"
    local elapsed=0
    while ! check_port "$port"; do
        if [[ $elapsed -ge $timeout ]]; then
            return 1
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_init() {
    local ver="$1"
    local bin="${OT_BASE}/${ver}/bin"
    local data="${OT_DATA}/${ver}"
    local log="${OT_LOG}/${ver}"
    local svc_user
    svc_user=$(resolve_service_user)

    log_info "Initializing OpenTenBase ${ver} cluster..."

    # Check binaries
    for b in initgtm gtm_ctl initdb pg_ctl postgres; do
        if [[ ! -x "${bin}/${b}" ]]; then
            log_error "Binary not found: ${bin}/${b}"
            exit 1
        fi
    done

    # Detect CPU cores and set GTM thread count
    local cpu_cores
    cpu_cores=$(nproc 2>/dev/null || echo "2")
    local gtm_threads=$((cpu_cores < 4 ? cpu_cores : 4))
    log_info "Detected ${cpu_cores} CPU cores, GTM threads: ${gtm_threads}"

    # Detect available RAM and auto-tune memory settings
    # OpenTenBase pooler cache requires ~1GB+ non-swappable shared memory per node
    # Minimum recommended: 3GB RAM for single-machine cluster (GTM + coord + dn1)
    local avail_ram_mb
    avail_ram_mb=$(awk '/MemTotal/ {printf "%d", $2/1024}' /proc/meminfo 2>/dev/null || echo "4096")
    log_info "Detected ${avail_ram_mb}MB RAM"
    local mem_max_conn mem_max_pool mem_shared_buf
    if [ "$avail_ram_mb" -lt 3000 ]; then
        log_warn "OpenTenBase requires at least 3GB RAM for a single-machine cluster."
        log_warn "Current system has ${avail_ram_mb}MB. Cluster may fail to start (OOM)."
        log_warn "Consider using a server with 4GB+ RAM."
        mem_max_conn=10; mem_max_pool=5; mem_shared_buf=16MB
    elif [ "$avail_ram_mb" -lt 4096 ]; then
        mem_max_conn=20; mem_max_pool=10; mem_shared_buf=32MB
    elif [ "$avail_ram_mb" -lt 8192 ]; then
        mem_max_conn=50; mem_max_pool=20; mem_shared_buf=128MB
    else
        mem_max_conn=100; mem_max_pool=100; mem_shared_buf=128MB
    fi
    log_info "Memory-tuned: max_connections=${mem_max_conn}, max_pool_size=${mem_max_pool}, shared_buffers=${mem_shared_buf}"

    # Create directories
    mkdir -p "${data}/gtm" "${data}/coord" "${data}/dn1" "${log}"
    if [[ "$svc_user" != "$(whoami)" ]]; then
        chown -R "${svc_user}:${svc_user}" "${data}" "${log}" 2>/dev/null || true
    fi

    # Initialize GTM
    log_info "Initializing GTM..."
    as_svc "$svc_user" "${bin}/initgtm -D ${data}/gtm -Z gtm" || {
        log_error "initgtm failed"
        exit 1
    }
    # Configure GTM
    sed -i "s/^port =.*/port = ${GTM_PORT}/" "${data}/gtm/gtm.conf"
    sed -i "s/^nodename =.*/nodename = 'gtm_master'/" "${data}/gtm/gtm.conf"

    # Initialize Datanode (with --master_gtm_* flags for GTM connection)
    log_info "Initializing Datanode..."
    as_svc "$svc_user" "${bin}/initdb" -D "${data}/dn1" \
        --nodename=dn1 --nodetype=datanode \
        --master_gtm_nodename=gtm_master --master_gtm_ip=127.0.0.1 --master_gtm_port="${GTM_PORT}" \
        --locale=C.UTF-8 -E UTF8 -U "${svc_user}" || {
        log_error "Datanode initdb failed"
        exit 1
    }

    # Configure Datanode (no gtm_host/gtm_port — those are not valid GUCs)
    cat >> "${data}/dn1/postgresql.conf" <<DNCONF

# -- OpenTenBase datanode config --
listen_addresses = '*'
port = ${DN_PORT}
forward_port = 6670
pooler_port = ${DN_POOLER_PORT}
pgxc_node_name = 'dn1'
log_directory = '${log}'
log_filename = 'dn1.log'
logging_collector = on
# -- memory auto-tuned for ${avail_ram_mb}MB RAM --
max_connections = ${mem_max_conn}
shared_buffers = ${mem_shared_buf}
DNCONF

    cat > "${data}/dn1/pg_hba.conf" <<HBA
# TYPE  DATABASE        USER            ADDRESS                 METHOD
local   all             all                                     trust
host    all             all             127.0.0.1/32            trust
host    all             all             ::1/128                 trust
HBA

    # Initialize Coordinator (with --master_gtm_* flags for GTM connection)
    log_info "Initializing Coordinator..."
    as_svc "$svc_user" "${bin}/initdb" -D "${data}/coord" \
        --nodename=coord --nodetype=coordinator \
        --master_gtm_nodename=gtm_master --master_gtm_ip=127.0.0.1 --master_gtm_port="${GTM_PORT}" \
        --locale=C.UTF-8 -E UTF8 -U "${svc_user}" || {
        log_error "Coordinator initdb failed"
        exit 1
    }

    # Configure Coordinator (no gtm_host/gtm_port — those are not valid GUCs)
    cat >> "${data}/coord/postgresql.conf" <<COORDCONF

# -- OpenTenBase coordinator config --
listen_addresses = '*'
port = ${COORD_PORT}
forward_port = 6669
pooler_port = ${COORD_POOLER_PORT}
pgxc_node_name = 'coord'
log_directory = '${log}'
log_filename = 'coord.log'
logging_collector = on
# -- memory auto-tuned for ${avail_ram_mb}MB RAM --
max_connections = ${mem_max_conn}
max_pool_size = ${mem_max_pool}
shared_buffers = ${mem_shared_buf}
COORDCONF

    cat > "${data}/coord/pg_hba.conf" <<HBA
# TYPE  DATABASE        USER            ADDRESS                 METHOD
local   all             all                                     trust
host    all             all             127.0.0.1/32            trust
host    all             all             ::1/128                 trust
HBA

    # Fix ownership
    if [[ "$svc_user" != "$(whoami)" ]]; then
        chown -R "${svc_user}:${svc_user}" "${data}" "${log}" 2>/dev/null || true
    fi

    log_ok "Cluster initialized (GTM + Coordinator + Datanode)"
    log_info "Data directory: ${data}"
    log_info "Log directory:  ${log}"
    log_info "Run 'opentenbase-ctl start' to start the cluster"
}

# ---------------------------------------------------------------------------
# Node registration — register all nodes via coordinator using SQL
# v5.0 uses pgxc_node system table, not gtm_host/gtm_port GUCs
# Uses template1 because 'postgres' database may not exist yet after initdb
# ---------------------------------------------------------------------------
register_nodes() {
    local ver="$1"
    local bin="${OT_BASE}/${ver}/bin"
    local data="${OT_DATA}/${ver}"
    local svc_user
    svc_user=$(resolve_service_user)

    local coord_psql="${bin}/psql -h 127.0.0.1 -p ${COORD_PORT} -U ${svc_user} -d template1 -X -q -v ON_ERROR_STOP=0"
    local dn_psql="${bin}/psql -h 127.0.0.1 -p ${DN_PORT} -U ${svc_user} -d template1 -X -q -v ON_ERROR_STOP=0"

    log_info "Registering nodes..."

    # Register GTM node in coordinator
    as_svc "$svc_user" bash -c "$coord_psql -c \"CREATE GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=${GTM_PORT}, PRIMARY);\"" 2>/dev/null || true
    as_svc "$svc_user" bash -c "$coord_psql -c \"ALTER GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=${GTM_PORT}, PRIMARY);\"" 2>/dev/null || true

    # Register coordinator node
    # FORWARD parameter is only valid in v5.0+
    if [[ "$ver" == "5.0" ]]; then
        as_svc "$svc_user" bash -c "$coord_psql -c \"CREATE NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT}, FORWARD=6669);\"" 2>/dev/null || true
        as_svc "$svc_user" bash -c "$coord_psql -c \"ALTER NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT}, FORWARD=6669);\"" 2>/dev/null || true
    else
        as_svc "$svc_user" bash -c "$coord_psql -c \"CREATE NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT});\"" 2>/dev/null || true
        as_svc "$svc_user" bash -c "$coord_psql -c \"ALTER NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT});\"" 2>/dev/null || true
    fi

    # Register datanode node
    # FORWARD parameter is only valid in v5.0+
    if [[ "$ver" == "5.0" ]]; then
        as_svc "$svc_user" bash -c "$coord_psql -c \"CREATE NODE dn1 WITH (TYPE='datanode', HOST='127.0.0.1', PORT=${DN_PORT}, FORWARD=6670, PRIMARY, PREFERRED);\"" 2>/dev/null || true
        as_svc "$svc_user" bash -c "$coord_psql -c \"ALTER NODE dn1 WITH (TYPE='datanode', HOST='127.0.0.1', PORT=${DN_PORT}, FORWARD=6670, PRIMARY, PREFERRED);\"" 2>/dev/null || true
    else
        as_svc "$svc_user" bash -c "$coord_psql -c \"CREATE NODE dn1 WITH (TYPE='datanode', HOST='127.0.0.1', PORT=${DN_PORT}, PRIMARY, PREFERRED);\"" 2>/dev/null || true
        as_svc "$svc_user" bash -c "$coord_psql -c \"ALTER NODE dn1 WITH (TYPE='datanode', HOST='127.0.0.1', PORT=${DN_PORT}, PRIMARY, PREFERRED);\"" 2>/dev/null || true
    fi

    # Reload pool on coordinator
    as_svc "$svc_user" bash -c "$coord_psql -c 'SELECT pgxc_pool_reload();'" >/dev/null 2>&1 || true

    # Propagate registrations to datanode
    if [[ -f "${data}/dn1/postmaster.pid" ]] && kill -0 "$(head -1 "${data}/dn1/postmaster.pid")" 2>/dev/null; then
        log_info "Propagating node registrations to datanode..."
        as_svc "$svc_user" bash -c "$dn_psql -c \"CREATE GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=${GTM_PORT}, PRIMARY);\"" 2>/dev/null || true
        as_svc "$svc_user" bash -c "$dn_psql -c \"ALTER GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=${GTM_PORT}, PRIMARY);\"" 2>/dev/null || true
        # FORWARD parameter is only valid in v5.0+
        if [[ "$ver" == "5.0" ]]; then
            as_svc "$svc_user" bash -c "$dn_psql -c \"CREATE NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT}, FORWARD=6669);\"" 2>/dev/null || true
            as_svc "$svc_user" bash -c "$dn_psql -c \"ALTER NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT}, FORWARD=6669);\"" 2>/dev/null || true
        else
            as_svc "$svc_user" bash -c "$dn_psql -c \"CREATE NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT});\"" 2>/dev/null || true
            as_svc "$svc_user" bash -c "$dn_psql -c \"ALTER NODE coord WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=${COORD_PORT});\"" 2>/dev/null || true
        fi
        as_svc "$svc_user" bash -c "$dn_psql -c 'SELECT pgxc_pool_reload();'" >/dev/null 2>&1 || true
    fi

    # Create 'postgres' database if it doesn't exist (initdb only creates template0/template1)
    local coord_psql_postgres="${bin}/psql -h 127.0.0.1 -p ${COORD_PORT} -U ${svc_user} -d template1 -X -t -A -q"
    if ! as_svc "$svc_user" bash -c "$coord_psql_postgres -c \"SELECT 1 FROM pg_database WHERE datname='postgres';\"" 2>/dev/null | grep -q 1; then
        log_info "Creating postgres database..."
        as_svc "$svc_user" "${bin}/createdb" -h 127.0.0.1 -p "${COORD_PORT}" -U "${svc_user}" postgres 2>/dev/null || true
    fi
}

# ---------------------------------------------------------------------------
# Node group and sharding setup
# Creates default node group and sharding map for DISTRIBUTE BY SHARD support
# ---------------------------------------------------------------------------
setup_node_group() {
    local ver="$1"
    local bin="${OT_BASE}/${ver}/bin"
    local svc_user
    svc_user=$(resolve_service_user)

    local coord_psql="${bin}/psql -h 127.0.0.1 -p ${COORD_PORT} -U ${svc_user} -d template1 -X -q -v ON_ERROR_STOP=0"
    local dn_psql="${bin}/psql -h 127.0.0.1 -p ${DN_PORT} -U ${svc_user} -d template1 -X -q -v ON_ERROR_STOP=0"

    # Check if node group already exists
    local has_group
    has_group=$(as_svc "$svc_user" bash -c "$coord_psql -t -A -c \"SELECT count(*) FROM pgxc_group WHERE group_name = 'default_group';\"" 2>/dev/null || echo "0")
    if [[ "$has_group" == "1" ]]; then
        return 0
    fi

    log_info "Setting up default node group..."

    # Get datanode OID from coordinator
    local dn_oid
    dn_oid=$(as_svc "$svc_user" bash -c "$coord_psql -t -A -c \"SELECT oid FROM pgxc_node WHERE node_name = 'dn1' AND node_type = 'D';\"" 2>/dev/null)
    if [[ -z "$dn_oid" ]]; then
        log_warn "Could not find datanode OID, skipping node group setup"
        return 0
    fi

    # Create node group on datanode first
    as_svc "$svc_user" bash -c "$dn_psql -c \"CREATE DEFAULT NODE GROUP default_group WITH (dn1);\"" 2>/dev/null || true

    # Insert node group into coordinator's catalog
    as_svc "$svc_user" bash -c "$coord_psql -c \"INSERT INTO pgxc_group (group_name, default_group, group_members) VALUES ('default_group', 1, '${dn_oid}');\"" 2>/dev/null || true

    # Reload pool
    as_svc "$svc_user" bash -c "$coord_psql -c 'SELECT pgxc_pool_reload();'" >/dev/null 2>&1 || true

    # Create sharding map
    log_info "Creating sharding map..."
    as_svc "$svc_user" bash -c "$coord_psql -c \"CREATE SHARDING GROUP TO GROUP default_group;\"" 2>/dev/null || true

    log_ok "Node group setup complete"
}

cmd_start() {
    local ver="$1"
    local bin="${OT_BASE}/${ver}/bin"
    local data="${OT_DATA}/${ver}"
    local log="${OT_LOG}/${ver}"
    local svc_user
    svc_user=$(resolve_service_user)

    # Check if already running
    if check_port "$GTM_PORT" && check_port "$COORD_PORT" && check_port "$DN_PORT"; then
        log_warn "Cluster appears to be already running"
        return 0
    fi

    log_info "Starting OpenTenBase ${ver} cluster..."

    # Start GTM
    if ! check_port "$GTM_PORT"; then
        log_info "Starting GTM..."
        as_svc "$svc_user" "${bin}/gtm_ctl start -D ${data}/gtm -Z gtm -l ${log}/gtm.log" || {
            log_error "GTM start failed"
            exit 1
        }
        if ! wait_for_port "$GTM_PORT" "$STARTUP_TIMEOUT"; then
            log_error "GTM not listening on port ${GTM_PORT} within ${STARTUP_TIMEOUT}s"
            tail -10 "${log}/gtm.log" 2>/dev/null || true
            exit 1
        fi
        log_ok "GTM started (port ${GTM_PORT})"
    else
        log_ok "GTM already running (port ${GTM_PORT})"
    fi

    # Start Datanode
    if ! check_port "$DN_PORT"; then
        log_info "Starting Datanode..."
        as_svc "$svc_user" "${bin}/pg_ctl start -D ${data}/dn1 -Z datanode -l ${log}/dn1.log" || {
            log_error "Datanode start failed"
            exit 1
        }
        if ! wait_for_port "$DN_PORT" "$STARTUP_TIMEOUT"; then
            log_error "Datanode not listening on port ${DN_PORT} within ${STARTUP_TIMEOUT}s"
            tail -10 "${log}/dn1.log" 2>/dev/null || true
            exit 1
        fi
        log_ok "Datanode started (port ${DN_PORT})"
    else
        log_ok "Datanode already running (port ${DN_PORT})"
    fi

    # Start Coordinator
    if ! check_port "$COORD_PORT"; then
        log_info "Starting Coordinator..."
        as_svc "$svc_user" "${bin}/pg_ctl start -D ${data}/coord -Z coordinator -l ${log}/coord.log" || {
            log_error "Coordinator start failed"
            exit 1
        }
        if ! wait_for_port "$COORD_PORT" "$STARTUP_TIMEOUT"; then
            log_error "Coordinator not listening on port ${COORD_PORT} within ${STARTUP_TIMEOUT}s"
            tail -10 "${log}/coord.log" 2>/dev/null || true
            exit 1
        fi
        log_ok "Coordinator started (port ${COORD_PORT})"
    else
        log_ok "Coordinator already running (port ${COORD_PORT})"
    fi

    # Register nodes and set up sharding after all processes are running
    register_nodes "$ver"
    setup_node_group "$ver"

    log_ok "Cluster started successfully"
}

cmd_stop() {
    local ver="$1"
    local bin="${OT_BASE}/${ver}/bin"
    local data="${OT_DATA}/${ver}"
    local svc_user
    svc_user=$(resolve_service_user)

    log_info "Stopping OpenTenBase ${ver} cluster..."

    # Stop in reverse order: Coordinator, Datanode, GTM
    if check_port "$COORD_PORT"; then
        log_info "Stopping Coordinator..."
        as_svc "$svc_user" "${bin}/pg_ctl stop -D ${data}/coord -Z coordinator -m fast" 2>/dev/null || true
        log_ok "Coordinator stopped"
    fi

    if check_port "$DN_PORT"; then
        log_info "Stopping Datanode..."
        as_svc "$svc_user" "${bin}/pg_ctl stop -D ${data}/dn1 -Z datanode -m fast" 2>/dev/null || true
        log_ok "Datanode stopped"
    fi

    if check_port "$GTM_PORT"; then
        log_info "Stopping GTM..."
        as_svc "$svc_user" "${bin}/gtm_ctl stop -D ${data}/gtm -Z gtm -m fast" 2>/dev/null || true
        log_ok "GTM stopped"
    fi

    log_ok "Cluster stopped"
}

cmd_status() {
    local ver="$1"
    local bin="${OT_BASE}/${ver}/bin"

    echo ""
    echo -e "${BOLD}OpenTenBase Cluster Status${NC}"
    echo -e "  Version:  ${ver}"
    echo -e "  Binaries: ${bin}"
    echo ""
    printf "  %-20s %-10s %-10s\n" "Component" "Port" "Status"
    printf "  %-20s %-10s %-10s\n" "---------" "----" "------"

    local all_running=true

    if check_port "$GTM_PORT"; then
        printf "  %-20s %-10s ${GREEN}%-10s${NC}\n" "GTM" "$GTM_PORT" "RUNNING"
    else
        printf "  %-20s %-10s ${RED}%-10s${NC}\n" "GTM" "$GTM_PORT" "STOPPED"
        all_running=false
    fi

    if check_port "$COORD_PORT"; then
        printf "  %-20s %-10s ${GREEN}%-10s${NC}\n" "Coordinator" "$COORD_PORT" "RUNNING"
    else
        printf "  %-20s %-10s ${RED}%-10s${NC}\n" "Coordinator" "$COORD_PORT" "STOPPED"
        all_running=false
    fi

    if check_port "$DN_PORT"; then
        printf "  %-20s %-10s ${GREEN}%-10s${NC}\n" "Datanode" "$DN_PORT" "RUNNING"
    else
        printf "  %-20s %-10s ${RED}%-10s${NC}\n" "Datanode" "$DN_PORT" "STOPPED"
        all_running=false
    fi

    echo ""

    if [[ "$all_running" == "true" ]]; then
        return 0
    else
        return 1
    fi
}

cmd_switch() {
    local new_ver="$1"
    local new_dir="${OT_BASE}/${new_ver}"

    if [[ ! -d "$new_dir" ]]; then
        log_error "Version directory not found: ${new_dir}"
        exit 1
    fi
    if [[ ! -x "${new_dir}/bin/postgres" ]]; then
        log_error "Binaries not found in ${new_dir}/bin/"
        exit 1
    fi

    local old_ver="none"
    if [[ -L "$CURRENT_LINK" ]]; then
        old_ver=$(basename "$(readlink "$CURRENT_LINK")")
    fi

    if [[ "$old_ver" == "$new_ver" ]]; then
        log_info "Already on version ${new_ver}"
        return 0
    fi

    log_info "Switching from ${old_ver} to ${new_ver}..."

    # Create config directory if needed
    mkdir -p "${OT_SYSCONF}/${new_ver}"

    # Update symlink
    ln -sfn "${OT_SYSCONF}/${new_ver}" "$CURRENT_LINK"

    log_ok "Switched to version ${new_ver}"
    log_info "Active version: $(readlink "$CURRENT_LINK")"

    if [[ "$old_ver" != "none" ]] && check_port "$COORD_PORT" 2>/dev/null; then
        echo ""
        log_warn "Services are still running with version ${old_ver}."
        log_warn "Run 'opentenbase-ctl stop' then 'opentenbase-ctl start' to use ${new_ver}."
    fi
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: opentenbase-ctl [OPTIONS] COMMAND

Commands:
  init              Initialize a new cluster (GTM + Coordinator + Datanode)
  start             Start all cluster components
  stop              Stop all cluster components
  status            Show cluster status
  restart           Stop then start the cluster
  switch VERSION    Switch active version

Options:
  -V, --version VERSION   Override active version
  -q, --quiet             Suppress informational output
  -h, --help              Show this help message

Examples:
  opentenbase-ctl init          # Initialize cluster
  opentenbase-ctl start         # Start cluster
  opentenbase-ctl status        # Check status
  opentenbase-ctl stop          # Stop cluster
  opentenbase-ctl switch 5.0    # Switch to version 5.0
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local command=""
    local version_arg=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -V|--version)
                OTB_VERSION_OVERRIDE="$2"
                shift 2
                ;;
            -q|--quiet)
                QUIET=true
                shift
                ;;
            init|start|stop|status|restart)
                command="$1"
                shift
                ;;
            switch)
                command="switch"
                version_arg="$2"
                shift 2
                ;;
            *)
                log_error "Unknown command: $1"
                usage
                exit 1
                ;;
        esac
    done

    if [[ -z "$command" ]]; then
        usage
        exit 1
    fi

    # Must be root for most operations
    if [[ "$(id -u)" -ne 0 ]] && [[ "$command" != "status" ]]; then
        log_error "This command requires root privileges. Use: sudo opentenbase-ctl $command"
        exit 1
    fi

    local ver
    ver=$(resolve_version)

    case "$command" in
        init)
            cmd_init "$ver"
            ;;
        start)
            cmd_start "$ver"
            ;;
        stop)
            cmd_stop "$ver"
            ;;
        status)
            cmd_status "$ver"
            ;;
        restart)
            cmd_stop "$ver"
            sleep 2
            cmd_start "$ver"
            ;;
        switch)
            cmd_switch "$version_arg"
            ;;
        *)
            log_error "Unknown command: $command"
            usage
            exit 1
            ;;
    esac
}

main "$@"
