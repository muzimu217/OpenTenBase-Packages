#!/bin/bash
# opentenbase-ctl - management script for OpenTenBase
# Usage: opentenbase-ctl {init|start|stop|restart|status|reload|psql [node]|logs [node]}

set -e

CONFIG="${OTB_CONFIG:-/etc/opentenbase/current/opentenbase.conf}"
[ -r "$CONFIG" ] || { echo "ERROR: cannot read $CONFIG" >&2; exit 1; }
# shellcheck disable=SC1090
. "$CONFIG"

OTB_BIN="${OTB_HOME}/bin"
TPL_DIR="$(dirname "$CONFIG")"

run_as_otb() {
    if [ "$(id -un)" = "$OTB_USER" ]; then
        PATH="$OTB_BIN:$PATH" LD_LIBRARY_PATH="$OTB_HOME/lib:${LD_LIBRARY_PATH:-}" "$@"
    else
        cd / && runuser -u "$OTB_USER" -- env PATH="$OTB_BIN:/usr/bin:/bin" LD_LIBRARY_PATH="$OTB_HOME/lib" "$@"
    fi
}

ensure_dirs() {
    local otb_version="${OTB_HOME##*/}"
    install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0750 /var/log/opentenbase
    install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0750 "/var/log/opentenbase/$otb_version"
    install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0700 /var/lib/opentenbase
    install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0755 /var/run/opentenbase
}

cmd_init() {
    ensure_dirs
    # 检测 CPU 核心数并设置 GTM 线程数
    CPU_CORES=$(nproc 2>/dev/null || echo "2")
    # GTM 线程数不能超过 CPU 核心数，避免 "binding threads failed" 错误
    GTM_THREADS=$((CPU_CORES < 4 ? CPU_CORES : 4))
    echo ">> Detected $CPU_CORES CPU cores, setting GTM threads to $GTM_THREADS"

    # 根据可用内存自动调整配置
    # OpenTenBase 连接池缓存需要大量不可 swap 的共享内存
    # 最低要求：3GB RAM（GTM + Coordinator + Datanode）
    AVAIL_RAM_MB=$(awk '/MemTotal/ {printf "%d", $2/1024}' /proc/meminfo 2>/dev/null || echo "4096")
    echo ">> Detected ${AVAIL_RAM_MB}MB RAM"
    if [ "$AVAIL_RAM_MB" -lt 3000 ]; then
        echo ">> WARNING: OpenTenBase requires at least 3GB RAM for a single-machine cluster."
        echo ">>          Current system has ${AVAIL_RAM_MB}MB. Cluster may fail to start."
        echo ">>          Consider using a server with 4GB+ RAM."
    fi
    if [ "$AVAIL_RAM_MB" -lt 4096 ]; then
        MEM_MAX_CONN=20
        MEM_MAX_POOL=10
        MEM_SHARED_BUF=32MB
    elif [ "$AVAIL_RAM_MB" -lt 8192 ]; then
        MEM_MAX_CONN=50
        MEM_MAX_POOL=20
        MEM_SHARED_BUF=128MB
    else
        MEM_MAX_CONN=100
        MEM_MAX_POOL=100
        MEM_SHARED_BUF=128MB
    fi
    echo ">> Memory-tuned: max_connections=$MEM_MAX_CONN, max_pool_size=$MEM_MAX_POOL, shared_buffers=$MEM_SHARED_BUF"

    # GTM
    if [ ! -f "$GTM_PGDATA/gtm.conf" ]; then
        install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0700 "$GTM_PGDATA"
        echo ">> initgtm $GTM_PGDATA"
        run_as_otb "$OTB_BIN/initgtm" -Z gtm -D "$GTM_PGDATA"
        # Override port
        sed -i "s/^port =.*/port = $GTM_PORT/" "$GTM_PGDATA/gtm.conf"
        sed -i "s/^nodename =.*/nodename = 'gtm_master'/" "$GTM_PGDATA/gtm.conf"
        # 注意：不追加 gtm_thread_count，该参数不被 GTM 二进制识别，会导致配置解析失败
        # 如果遇到 "binding threads failed" 错误，请手动编辑 gtm.conf 设置线程数
    else
        echo ">> gtm already initialised, skipping"
    fi

    # Coordinator
    if [ ! -f "$COORD_PGDATA/PG_VERSION" ]; then
        install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0700 "$COORD_PGDATA"
        echo ">> initdb coordinator at $COORD_PGDATA"
        run_as_otb "$OTB_BIN/initdb" -D "$COORD_PGDATA" --nodename="$COORD_NODENAME" --nodetype=coordinator \
            --master_gtm_nodename=gtm_master --master_gtm_ip=127.0.0.1 --master_gtm_port="$GTM_PORT" \
            --locale=C.UTF-8 -E UTF8 -U "$OTB_USER"
        {
            echo ""
            echo "# --- opentenbase coordinator overrides ---"
            echo "listen_addresses = '*'"
            echo "port = $COORD_PORT"
            echo "forward_port = ${COORD_FORWARD_PORT:-6669}"
            echo "pooler_port = ${COORD_POOLER_PORT:-6667}"
            echo "pgxc_node_name = '$COORD_NODENAME'"
            echo "log_directory = '/var/log/opentenbase'"
            echo "log_filename = 'coord.log'"
            echo "logging_collector = on"
            echo "# --- memory auto-tuned for ${AVAIL_RAM_MB}MB RAM ---"
            echo "max_connections = $MEM_MAX_CONN"
            echo "max_pool_size = $MEM_MAX_POOL"
            echo "shared_buffers = $MEM_SHARED_BUF"
        } >> "$COORD_PGDATA/postgresql.conf"
        cp "$TPL_DIR/pg_hba.conf.template" "$COORD_PGDATA/pg_hba.conf"
        chown "$OTB_USER:$OTB_GROUP" "$COORD_PGDATA/pg_hba.conf"
    else
        echo ">> coord already initialised, skipping"
    fi

    # Datanode 1
    if [ ! -f "$DN1_PGDATA/PG_VERSION" ]; then
        install -d -o "$OTB_USER" -g "$OTB_GROUP" -m 0700 "$DN1_PGDATA"
        echo ">> initdb datanode at $DN1_PGDATA"
        run_as_otb "$OTB_BIN/initdb" -D "$DN1_PGDATA" --nodename="$DN1_NODENAME" --nodetype=datanode \
            --master_gtm_nodename=gtm_master --master_gtm_ip=127.0.0.1 --master_gtm_port="$GTM_PORT" \
            --locale=C.UTF-8 -E UTF8 -U "$OTB_USER"
        {
            echo ""
            echo "# --- opentenbase datanode overrides ---"
            echo "listen_addresses = '*'"
            echo "port = $DN1_PORT"
            echo "forward_port = ${DN1_FORWARD_PORT:-6670}"
            echo "pooler_port = ${DN1_POOLER_PORT:-6668}"
            echo "pgxc_node_name = '$DN1_NODENAME'"
            echo "log_directory = '/var/log/opentenbase'"
            echo "log_filename = 'dn1.log'"
            echo "logging_collector = on"
            echo "# --- memory auto-tuned for ${AVAIL_RAM_MB}MB RAM ---"
            echo "max_connections = $MEM_MAX_CONN"
            echo "shared_buffers = $MEM_SHARED_BUF"
        } >> "$DN1_PGDATA/postgresql.conf"
        cp "$TPL_DIR/pg_hba.conf.template" "$DN1_PGDATA/pg_hba.conf"
        chown "$OTB_USER:$OTB_GROUP" "$DN1_PGDATA/pg_hba.conf"
    else
        echo ">> dn1 already initialised, skipping"
    fi

    echo ">> init complete. Run: opentenbase-ctl start"
}

wait_for_port() {
    local port=$1 max=60
    for i in $(seq 1 $max); do
        # Use ss to check both IPv4 and IPv6 (GTM may bind to :: dual-stack)
        if command -v ss >/dev/null 2>&1; then
            ss -tlnp 2>/dev/null | grep -q ":${port} " && return 0
        elif command -v netstat >/dev/null 2>&1; then
            netstat -tlnp 2>/dev/null | grep -q ":${port} " && return 0
        else
            (echo > "/dev/tcp/127.0.0.1/$port") 2>/dev/null && return 0
        fi
        sleep 1
    done
    return 1
}

start_gtm() {
    if pgrep -u "$OTB_USER" -f "gtm -D $GTM_PGDATA" >/dev/null 2>&1; then
        echo "  gtm already running"
        return 0
    fi
    echo "  starting gtm"
    run_as_otb "$OTB_BIN/gtm_ctl" -Z gtm -D "$GTM_PGDATA" -l "$GTM_LOG" start
    wait_for_port "$GTM_PORT" || { echo "gtm port $GTM_PORT not listening"; return 1; }
}

start_dn1() {
    if [ -f "$DN1_PGDATA/postmaster.pid" ] && \
       kill -0 "$(head -1 "$DN1_PGDATA/postmaster.pid")" 2>/dev/null; then
        echo "  dn1 already running"
        return 0
    fi
    echo "  starting dn1"
    run_as_otb "$OTB_BIN/pg_ctl" -Z datanode -D "$DN1_PGDATA" -l "$DN1_LOG" \
        -o "-i" start
    wait_for_port "$DN1_PORT" || { echo "dn1 port $DN1_PORT not listening"; return 1; }
}

start_coord() {
    if [ -f "$COORD_PGDATA/postmaster.pid" ] && \
       kill -0 "$(head -1 "$COORD_PGDATA/postmaster.pid")" 2>/dev/null; then
        echo "  coord already running"
        return 0
    fi
    echo "  starting coord"
    run_as_otb "$OTB_BIN/pg_ctl" -Z coordinator -D "$COORD_PGDATA" -l "$COORD_LOG" \
        -o "-i" start
    wait_for_port "$COORD_PORT" || { echo "coord port $COORD_PORT not listening"; return 1; }
}

register_nodes() {
    # Register all nodes via coordinator using CREATE NODE / CREATE GTM NODE
    # v5.0 uses pgxc_node system table instead of gtm_host/gtm_port GUCs
    # Use template1 because 'postgres' database may not exist yet after initdb
    local psql="$OTB_BIN/psql -h 127.0.0.1 -p $COORD_PORT -U $OTB_USER -d template1 -X -q -v ON_ERROR_STOP=0"
    local dn1_psql="$OTB_BIN/psql -h 127.0.0.1 -p $DN1_PORT -U $OTB_USER -d template1 -X -q -v ON_ERROR_STOP=0"

    echo "  registering GTM node in pgxc_node ..."
    run_as_otb bash -c "$psql -c \"CREATE GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=$GTM_PORT, PRIMARY);\"" 2>/dev/null || true
    run_as_otb bash -c "$psql -c \"ALTER GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=$GTM_PORT, PRIMARY);\"" 2>/dev/null || true

    local coord_fwd=${COORD_FORWARD_PORT:-6669}
    local dn1_fwd=${DN1_FORWARD_PORT:-6670}

    echo "  registering coordinator node ..."
    run_as_otb bash -c "$psql -c \"CREATE NODE $COORD_NODENAME WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=$COORD_PORT, FORWARD=$coord_fwd);\"" 2>/dev/null || true
    run_as_otb bash -c "$psql -c \"ALTER NODE $COORD_NODENAME WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=$COORD_PORT, FORWARD=$coord_fwd);\"" 2>/dev/null || true

    echo "  registering datanode node ..."
    run_as_otb bash -c "$psql -c \"CREATE NODE $DN1_NODENAME WITH (TYPE='datanode', HOST='127.0.0.1', PORT=$DN1_PORT, FORWARD=$dn1_fwd, PRIMARY, PREFERRED);\"" 2>/dev/null || true
    run_as_otb bash -c "$psql -c \"ALTER NODE $DN1_NODENAME WITH (TYPE='datanode', HOST='127.0.0.1', PORT=$DN1_PORT, FORWARD=$dn1_fwd, PRIMARY, PREFERRED);\"" 2>/dev/null || true

    echo "  reloading connection pool ..."
    run_as_otb bash -c "$psql -c 'SELECT pgxc_pool_reload();'" >/dev/null 2>&1 || true

    # Propagate node registrations to datanode directly (if datanode is running)
    if [ -f "$DN1_PGDATA/postmaster.pid" ] && \
       kill -0 "$(head -1 "$DN1_PGDATA/postmaster.pid")" 2>/dev/null; then
        echo "  propagating nodes to datanode ..."
        # Register GTM on datanode
        run_as_otb bash -c "$dn1_psql -c \"CREATE GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=$GTM_PORT, PRIMARY);\"" 2>/dev/null || true
        run_as_otb bash -c "$dn1_psql -c \"ALTER GTM NODE gtm_master WITH (HOST='127.0.0.1', PORT=$GTM_PORT, PRIMARY);\"" 2>/dev/null || true
        # Register coordinator on datanode (needed for pooler GUC validation)
        run_as_otb bash -c "$dn1_psql -c \"CREATE NODE $COORD_NODENAME WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=$COORD_PORT, FORWARD=$coord_fwd);\"" 2>/dev/null || true
        run_as_otb bash -c "$dn1_psql -c \"ALTER NODE $COORD_NODENAME WITH (TYPE='coordinator', HOST='127.0.0.1', PORT=$COORD_PORT, FORWARD=$coord_fwd);\"" 2>/dev/null || true
        run_as_otb bash -c "$dn1_psql -c 'SELECT pgxc_pool_reload();'" >/dev/null 2>&1 || true
    fi

    # Create 'postgres' database if it doesn't exist (initdb only creates template0/template1)
    if ! run_as_otb bash -c "$psql -t -A -c \"SELECT 1 FROM pg_database WHERE datname='postgres';\"" 2>/dev/null | grep -q 1; then
        echo "  creating postgres database ..."
        run_as_otb "$OTB_BIN/createdb" -h 127.0.0.1 -p "$COORD_PORT" -U "$OTB_USER" postgres 2>/dev/null || true
    fi
}

setup_node_group() {
    # Create default node group and sharding map if not already done
    # Use template1 because pgxc_group is a global catalog visible from any database
    local psql="$OTB_BIN/psql -h 127.0.0.1 -p $COORD_PORT -U $OTB_USER -d template1 -X -q -v ON_ERROR_STOP=0"
    local dn1_psql="$OTB_BIN/psql -h 127.0.0.1 -p $DN1_PORT -U $OTB_USER -d template1 -X -q -v ON_ERROR_STOP=0"

    # Check if node group already exists on coordinator
    local has_group
    has_group=$(run_as_otb bash -c "$psql -t -A -c \"SELECT count(*) FROM pgxc_group WHERE group_name = 'default_group';\"" 2>/dev/null || echo "0")
    if [ "$has_group" = "1" ]; then
        return 0
    fi

    echo "  setting up default node group ..."

    # Get datanode OID from coordinator
    local dn_oid
    dn_oid=$(run_as_otb bash -c "$psql -t -A -c \"SELECT oid FROM pgxc_node WHERE node_name = '$DN1_NODENAME' AND node_type = 'D';\"" 2>/dev/null)
    if [ -z "$dn_oid" ]; then
        echo "  WARNING: could not find datanode OID, skipping node group setup"
        return 0
    fi

    # Create node group on datanode first
    run_as_otb bash -c "$dn1_psql -c \"CREATE DEFAULT NODE GROUP default_group WITH ($DN1_NODENAME);\"" 2>/dev/null || true

    # Insert node group into coordinator's catalog
    run_as_otb bash -c "$psql -c \"INSERT INTO pgxc_group (group_name, default_group, group_members) VALUES ('default_group', 1, '$dn_oid');\"" 2>/dev/null || true

    # Reload pool so coordinator sees the group
    run_as_otb bash -c "$psql -c 'SELECT pgxc_pool_reload();'" >/dev/null 2>&1 || true

    # Create sharding group
    echo "  creating sharding map ..."
    run_as_otb bash -c "$psql -c \"CREATE SHARDING GROUP TO GROUP default_group;\"" 2>/dev/null || true

    echo "  node group setup complete"
}

stop_gtm() {
    echo "  stopping gtm"
    run_as_otb "$OTB_BIN/gtm_ctl" -Z gtm -D "$GTM_PGDATA" stop -m fast || true
}
stop_dn1() {
    echo "  stopping dn1"
    run_as_otb "$OTB_BIN/pg_ctl" -D "$DN1_PGDATA" stop -m fast || true
}
stop_coord() {
    echo "  stopping coord"
    run_as_otb "$OTB_BIN/pg_ctl" -D "$COORD_PGDATA" stop -m fast || true
}

cmd_start() {
    ensure_dirs
    local failed=0
    # Start ALL nodes first: gtm -> coord -> dn1
    # (Datanode finds GTM from its local postgresql.conf, not from pgxc_node)
    for n in $START_ORDER; do
        case $n in
            gtm) start_gtm || { echo "ERROR: failed to start gtm"; failed=1; } ;;
            coord) start_coord || { echo "ERROR: failed to start coord"; failed=1; } ;;
            dn1) start_dn1 || { echo "ERROR: failed to start dn1"; failed=1; } ;;
        esac
    done
    if [ "$failed" -eq 1 ]; then
        echo ">> WARNING: some nodes failed to start, attempting registration anyway"
    fi
    # Register nodes AFTER all processes are running.
    # Calling pgxc_pool_reload() before the datanode is listening causes the
    # pooler to block on a TCP connect (~120 s) which exceeds the test timeout.
    register_nodes
    # Set up node group and sharding map for DISTRIBUTE BY SHARD support
    setup_node_group
    echo ">> start complete"
}

cmd_stop() {
    for n in $STOP_ORDER; do
        case $n in
            gtm) stop_gtm ;;
            dn1) stop_dn1 ;;
            coord) stop_coord ;;
        esac
    done
    echo ">> stop complete"
}

cmd_status() {
    local ok=1
    for n in $ENABLED_NODES; do
        case $n in
            gtm)
                if pgrep -u "$OTB_USER" -f "gtm -D $GTM_PGDATA" >/dev/null 2>&1; then
                    echo "gtm:   RUNNING"
                else echo "gtm:   STOPPED"; ok=0; fi ;;
            dn1)
                if pgrep -u "$OTB_USER" -f "postgres.*--datanode.*-D $DN1_PGDATA" >/dev/null 2>&1 || \
                   ([ -f "$DN1_PGDATA/postmaster.pid" ] && \
                    kill -0 "$(head -1 "$DN1_PGDATA/postmaster.pid")" 2>/dev/null); then
                    echo "dn1:   RUNNING"
                else echo "dn1:   STOPPED"; ok=0; fi ;;
            coord)
                if pgrep -u "$OTB_USER" -f "postgres.*--coordinator.*-D $COORD_PGDATA" >/dev/null 2>&1 || \
                   ([ -f "$COORD_PGDATA/postmaster.pid" ] && \
                    kill -0 "$(head -1 "$COORD_PGDATA/postmaster.pid")" 2>/dev/null); then
                    echo "coord: RUNNING"
                else echo "coord: STOPPED"; ok=0; fi ;;
        esac
    done
    [ $ok -eq 1 ] && return 0 || return 3
}

cmd_restart() { cmd_stop; sleep 2; cmd_start; }
cmd_reload()  {
    run_as_otb "$OTB_BIN/pg_ctl" -D "$COORD_PGDATA" reload || true
    run_as_otb "$OTB_BIN/pg_ctl" -D "$DN1_PGDATA" reload || true
}
cmd_psql() {
    local node=${1:-coord}
    case $node in
        coord) exec run_as_otb "$OTB_BIN/psql" -h 127.0.0.1 -p "$COORD_PORT" -U "$OTB_USER" -d postgres ;;
        dn1)   exec run_as_otb "$OTB_BIN/psql" -h 127.0.0.1 -p "$DN1_PORT" -U "$OTB_USER" -d postgres ;;
        *) echo "unknown node: $node"; exit 2 ;;
    esac
}
cmd_logs() {
    local node=${1:-coord}
    case $node in
        gtm) exec tail -f "$GTM_LOG" ;;
        dn1) exec tail -f "$DN1_LOG" ;;
        coord) exec tail -f "$COORD_LOG" ;;
        *) echo "unknown node: $node"; exit 2 ;;
    esac
}

case "${1:-}" in
    init) cmd_init ;;
    start) cmd_start ;;
    stop) cmd_stop ;;
    restart) cmd_restart ;;
    reload) cmd_reload ;;
    status) cmd_status ;;
    psql) shift; cmd_psql "$@" ;;
    logs) shift; cmd_logs "$@" ;;
    *)
        cat >&2 <<USAGE
Usage: opentenbase-ctl {init|start|stop|restart|reload|status|psql [node]|logs [node]}
USAGE
        exit 2 ;;
esac
