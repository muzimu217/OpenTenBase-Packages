# OpenTenBase pg_hba.conf template
# WARNING: 'trust' means no password is required for connections from that source.
# Only use 'trust' for localhost/loopback connections in development environments.
# For production, use 'scram-sha-256' or 'md5' for all remote connections.
local   all             all                                     trust
host    all             all             127.0.0.1/32            trust
host    all             all             ::1/128                 trust
host    all             all             0.0.0.0/0               scram-sha-256
