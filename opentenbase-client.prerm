#!/bin/sh
set -e
case "$1" in
    remove|deconfigure)
        update-alternatives --remove opentenbase-psql /usr/lib/opentenbase/bin/psql || true
        update-alternatives --remove opentenbase-pg_dump /usr/lib/opentenbase/bin/pg_dump || true
        update-alternatives --remove opentenbase-pg_restore /usr/lib/opentenbase/bin/pg_restore || true
        ;;
esac

#DEBHELPER#

exit 0
